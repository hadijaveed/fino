{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@db/*": ["./server/db/*"]
    }
  },
  "include": ["server/**/*.ts", "mcp/**/*.ts"],
  "exclude": ["node_modules", "client"]
}
